# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.
#
# NOTE: When running via GitHub Actions, you do NOT need any of these.
# GitHub Actions provides GITHUB_TOKEN automatically, and GITHUB_REPO
# is set from github.repository. No secrets to configure.
#
# These are only needed if you want to test issue creation locally.

# Your GitHub personal access token (needs repo + issues scope)
# Generate at: github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your repo in owner/name format
GITHUB_REPO=your-username/telecom-tracker